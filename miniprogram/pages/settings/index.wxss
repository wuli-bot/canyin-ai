.setting-row { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; }
.setting-label { font-size: 28rpx; color: var(--color-text); }
.setting-value { font-size: 28rpx; color: var(--color-text-secondary); }
.hint { font-size: 24rpx; color: var(--color-text-secondary); margin-top: 16rpx; opacity: 0.6; }
